{
  "name": "lumina-dev",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter desktop dev",
    "build": "pnpm --filter @linux-dev-home/shared build && pnpm --filter desktop build",
    "pack:linux": "pnpm --filter desktop pack:linux",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @linux-dev-home/shared build && pnpm --filter shared test && pnpm --filter desktop test",
    "test:roundtrip": "pnpm --filter @linux-dev-home/shared build && pnpm --filter desktop test:roundtrip",
    "test:e2e": "pnpm --filter @linux-dev-home/shared build && pnpm --filter desktop test:e2e",
    "test:coverage": "pnpm --filter @linux-dev-home/shared build && pnpm --filter desktop test:coverage",
    "audit:prod": "pnpm audit --prod --audit-level=high",
    "smoke": "bash scripts/smoke-ci.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.0"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  }
}
