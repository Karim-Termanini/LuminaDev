{
  "name": "lumina-dev",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter desktop dev",
    "build": "pnpm --filter @linux-dev-home/shared build && pnpm --filter desktop build",
    "pack:linux": "pnpm --filter desktop pack:linux",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter shared test"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  }
}
