{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LuminaDev",
  "version": "0.1.0",
  "identifier": "io.github.karimodora.luminadev",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build:web",
    "frontendDist": "../out/renderer",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "title": "LuminaDev",
        "width": 1280,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../../data/icons/hicolor/128x128/apps/io.github.karimodora.LinuxDevHome.png"
    ]
  }
}
