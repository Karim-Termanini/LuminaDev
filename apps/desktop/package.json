{
  "name": "desktop",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Linux developer home dashboard",
  "author": "Karim Termanini",
  "homepage": "https://github.com/Karim-Termanini/LuminaDev",
  "desktopName": "io.github.karimodora.LinuxDevHome.desktop",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite --config vite.renderer.config.ts",
    "build": "pnpm build:web && node scripts/copy-docker-profiles.mjs",
    "build:web": "vite build --config vite.renderer.config.ts",
    "build:tauri": "pnpm icons:generate && tauri build",
    "icons:generate": "node scripts/generate-tauri-icons.mjs",
    "i18n:stubs": "node scripts/gen-i18n-stubs.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.web.json",
    "test": "pnpm --filter @linux-dev-home/shared build && vitest run",
    "test:roundtrip": "vitest run src/renderer/src/pages/dockerContractErrorRoundtrip.test.ts src/renderer/src/pages/profileContractErrorRoundtrip.test.ts src/renderer/src/pages/scaffoldContractErrorRoundtrip.test.ts",
    "test:e2e": "vitest run src/renderer/src/pages/criticalScenarios.unit.test.ts src/renderer/src/pages/moduleAvailability.test.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@linux-dev-home/shared": "workspace:*",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-opener": "2.5.4",
    "@vscode/codicons": "^0.0.45",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.2",
    "i18next": "^26.3.0",
    "i18next-resources-to-backend": "^1.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.30.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
