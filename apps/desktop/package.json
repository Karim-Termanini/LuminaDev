{
  "name": "desktop",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Linux developer home dashboard",
  "author": "Karim Termanini",
  "homepage": "https://github.com/Karim-Termanini/LuminaDev",
  "desktopName": "io.github.karimodora.LinuxDevHome.desktop",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite --config vite.renderer.config.ts",
    "build": "pnpm build:web && node scripts/copy-docker-profiles.mjs",
    "build:web": "vite build --config vite.renderer.config.ts",
    "build:tauri": "tauri build",
    "i18n:stubs": "node scripts/gen-i18n-stubs.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:integration": "vitest run src/renderer/src/pages/dockerIpc.integration.test.ts",
    "test:e2e": "vitest run src/renderer/src/pages/criticalScenarios.e2e.test.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@linux-dev-home/shared": "workspace:*",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-opener": "2.5.4",
    "@vscode/codicons": "^0.0.36",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.10.2",
    "i18next": "^26.3.0",
    "i18next-resources-to-backend": "^1.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.28.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.10.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
